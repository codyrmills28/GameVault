{
  "name": "realmswap-mvp",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "db:push": "cross-env DATABASE_URL=\"file:./dev.db\" prisma db push",
    "electron:dev": "cross-env GAMEVAULT_DEV=1 concurrently -k \"next dev\" \"wait-on http://localhost:3000/start && electron .\"",
    "prepackage": "node scripts/make-template-db.js && next build",
    "electron:build": "npm run prepackage && electron-builder --publish never",
    "bot": "tsx src/bot/index.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "bcryptjs": "^2.4.3",
    "chrono-node": "^2.9.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.6.1",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "framer-motion": "^12.42.0",
    "gamedig": "^5.3.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.395.0",
    "nat-api": "^0.3.1",
    "next": "^14.2.4",
    "nodemailer": "^9.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "sonner": "^2.0.7",
    "ssh2-sftp-client": "^11.0.0",
    "tailwind-merge": "^2.3.0",
    "tar": "^7.5.17",
    "tsx": "^4.22.4",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/gamedig": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/tar": "^6.1.13",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.38",
    "prisma": "^5.15.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vitest": "^1.6.1",
    "wait-on": "^9.0.10"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
